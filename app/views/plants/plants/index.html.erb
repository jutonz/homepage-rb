<%= render(HeaderComponent.new(title: "Plants")) do |c| %>
  <%= c.with_crumb("Home", home_path) %>
  <%= c.with_action do %>
    <%= link_to("Inbox", inbox_images_path, class: "button") %>
  <% end %>
  <%= c.with_action do %>
    <%= link_to("New Plant", new_plant_path, class: "button") %>
  <% end %>
<% end %>

<div class="flex gap-4 flex-wrap justify-center sm:justify-start">
  <% @plants.each do |plant| %>
    <%= link_to(plant_path(plant), data: {role: "plant"}) do %>
      <%= render(Plants::PlantCardComponent.new(plant:)) %>
    <% end %>
  <% end %>

  <span class="hidden only:block text-gray-500">No plants yet</span>
</div>
