<div data-controller="dropzone dialog">
  <%= simple_form_for(
    @bulk_upload,
    url: gallery_bulk_upload_path(@gallery),
    html: {
      data: {
        action: "submit->dropzone#handleSubmit"
      }
    }
  ) do |form| %>
    <div
      class="flex justify-between items-center
        mt-2 mb-3"
    >
      <h3 class="text-lg">Tags to apply</h3>
      <button
        type="button"
        class="button"
        data-action="dialog#open"
      >Add tags</button>
    </div>

    <div
      id="bulk-upload-selected-tags"
      class="flex flex-wrap gap-2 mb-4"
    >
      <span class="text-gray-500 hidden only:block">
        No tags selected.
      </span>
    </div>

    <div id="bulk-upload-tag-ids"></div>

    <div
      class="dropzone"
      data-dropzone-target="dropArea"
      role="button"
      tabindex="0"
      aria-label="Upload images by dragging
        them here or by browsing for files"
      data-action="
        dragenter->dropzone#dragEnter
        dragover->dropzone#dragOver
        dragleave->dropzone#dragLeave
        drop->dropzone#drop
        click->dropzone#openFilePicker
        keydown.enter->dropzone#openFilePicker
        keydown.space->dropzone#openFilePicker
      "
    >
      <p class="text-lg">
        Drag images here or click to browse
      </p>
      <p class="text-sm text-gray-400 mt-1">
        Supports multiple files
      </p>
    </div>

    <%= form.input(
      :files,
      as: :file,
      label: false,
      wrapper: false,
      input_html: {
        direct_upload: true,
        multiple: true,
        class: "hidden",
        data: {
          dropzone_target: "fileInput",
          action: "change->dropzone#filesSelected"
        }
      }
    ) %>

    <div
      data-dropzone-target="fileList"
      class="dropzone__file-list"
    ></div>

    <%= form.button(
      :submit,
      data: {dropzone_target: "submitButton"}
    ) %>
  <% end %>

  <dialog
    data-controller="tag-search"
    data-dialog-target="dialog"
    class="m-0 p-0 border-0 bg-white w-screen
      max-w-none h-[100dvh] max-h-[100dvh]
      open:flex flex-col backdrop:bg-black/50"
  >
    <div
      class="flex-none px-4 py-3 border-b
        flex items-center gap-3"
    >
      <h3 class="text-lg grow">Search tags</h3>
      <button
        type="button"
        class="button"
        data-action="dialog#close"
      >Done</button>
    </div>

    <div class="flex-1 overflow-y-auto px-4 py-3">
      <%= simple_form_for(
        @tag_search,
        url: gallery_tag_search_path(@gallery),
        method: :get,
        html: {
          data: {
            turbo_frame:
              "bulk-upload-tag-search-results",
            controller: "auto-submit-form"
          }
        }
      ) do |form| %>
        <%= hidden_field_tag(
          "tag_search[mode]", "bulk_upload_tag"
        ) %>
        <%= hidden_field_tag(
          "tag_search[turbo_frame_tag]",
          "bulk-upload-tag-search-results"
        ) %>
        <div class="flex w-full gap-3 mb-4">
          <%= form.input(
            :query,
            label: false,
            wrapper_html: {class: "grow"},
            input_html: {
              autofocus: true,
              autocorrect: "off",
              autocomplete: "off",
              aria: {label: "Tag search query"},
              data: {
                action: [
                  "input->auto-submit-form#submit",
                  "keydown->tag-search#submitFirstResult"
                ].join(" ")
              }
            }
          ) %>
          <%= form.button(:submit, "Search") %>
        </div>
      <% end %>

      <div
        id="bulk-upload-modal-selected-tags"
        class="flex flex-wrap gap-2 mb-4"
      >
        <span class="text-gray-500 hidden only:block">
          No tags selected.
        </span>
      </div>

      <div data-tag-search-target="results">
        <%= turbo_frame_tag(
          "bulk-upload-tag-search-results"
        ) %>
      </div>
    </div>
  </dialog>
</div>
