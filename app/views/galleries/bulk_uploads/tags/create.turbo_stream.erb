<%= turbo_stream.remove(
  "bulk-upload-tag-#{@tag.id}"
) %>
<%= turbo_stream.remove(
  "bulk-upload-modal-tag-#{@tag.id}"
) %>
<%= turbo_stream.remove(
  "bulk-upload-tag-input-#{@tag.id}"
) %>
<%= turbo_stream.append("bulk-upload-selected-tags") do %>
  <%= render(Galleries::BulkUploadSelectedTagComponent.new(
    tag: @tag,
    frame_id: "bulk-upload-tag-#{@tag.id}"
  )) %>
<% end %>
<%= turbo_stream.append(
  "bulk-upload-modal-selected-tags"
) do %>
  <%= render(Galleries::BulkUploadSelectedTagComponent.new(
    tag: @tag,
    frame_id: "bulk-upload-modal-tag-#{@tag.id}"
  )) %>
<% end %>
<%= turbo_stream.append("bulk-upload-tag-ids") do %>
  <input
    type="hidden"
    name="bulk_upload[tag_ids][]"
    value="<%= @tag.id %>"
    id="bulk-upload-tag-input-<%= @tag.id %>"
  />
<% end %>
<%= turbo_stream.remove(
  "tag-search-result-#{@tag.id}"
) %>
