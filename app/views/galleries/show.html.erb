<% content_for :title, "#{@gallery.name} Gallery" %>

<% if @select_mode %>
<div data-controller="gallery-bulk-tag dialog">
<% else %>
<div>
<% end %>
  <%= render(HeaderComponent.new(
    title: @gallery.name
  )) do |c| %>
    <%= c.with_crumb("Home", home_path) %>
    <%= c.with_crumb("Galleries", galleries_path) %>

    <% unless @select_mode %>
      <%= c.with_action do %>
        <%= link_to(
          "Add images",
          new_gallery_bulk_upload_path(@gallery),
          class: "button"
        ) %>
      <% end %>

      <%= c.with_action do %>
        <%= link_to(
          "Tags",
          gallery_tags_path(@gallery),
          class: "button"
        ) %>
      <% end %>

      <%= c.with_action do %>
        <%= link_to(
          "Books",
          gallery_books_path(@gallery),
          class: "button"
        ) %>
      <% end %>

      <%= c.with_action do %>
        <%= link_to(
          "Edit",
          edit_gallery_path(@gallery),
          class: "button"
        ) %>
      <% end %>

      <%= c.with_action do %>
        <button
          type="button"
          class="button"
          disabled
          data-controller="select-mode"
          data-action="click->select-mode#enter"
        >
          Select
        </button>
      <% end %>

      <%= c.with_action do %>
        <%= button_to(
          "Delete",
          gallery_path(@gallery),
          method: "delete",
          data: {turbo_confirm: "Are you sure?"},
          class: "button button--danger"
        ) %>
      <% end %>
    <% end %>

    <% if @select_mode %>
      <%= c.with_action do %>
        <button
          type="button"
          class="button"
          data-action="gallery-bulk-tag#prepare dialog#open"
        >
          Add tag
        </button>
      <% end %>

      <%= c.with_action do %>
        <%= button_to(
          "Delete",
          gallery_bulk_delete_path(
            @gallery,
            **request.query_parameters
          ),
          method: :post,
          params: {
            bulk_delete: {
              image_ids: @selected_ids
            }
          },
          data: {
            turbo_confirm:
              "Delete the selected images? " \
              "This cannot be undone."
          },
          class: "button button--danger"
        ) %>
      <% end %>

      <%= c.with_action do %>
        <%= link_to(
          "Cancel",
          gallery_path(
            @gallery,
            tag_ids: params[:tag_ids],
            page: params[:page]
          ),
          class: "button"
        ) %>
      <% end %>
    <% end %>
  <% end %>

  <div class="mb-6">
    <%= render(PillComponent.new(
      text: "#{@gallery.images.processed.size} images",
      color: :blue
    )) %>
  </div>

  <div
    class="grid gap-5 grid-cols-1 lg:grid-cols-4"
    data-controller="gallery-select"
    data-gallery-select-mode-value="<%= !!@select_mode %>"
    data-action="turbo:frame-render->gallery-select#handleFrameRender"
  >
    <%= turbo_frame_tag("gallery-filters") do %>
      <%= render(
        partial: "filters",
        locals: {
          tags: @filter_tags
        }
      ) %>
    <% end %>

    <div class="lg:col-span-3">
      <%= turbo_frame_tag("gallery-images") do %>
        <%= render(
          partial: "images",
          locals: {
            images: @images,
            select_mode: @select_mode,
            selected_ids: @selected_ids
          }
        ) %>
      <% end %>
    </div>
  </div>

  <% if @select_mode %>
    <%= render(Galleries::TagSearchDialogComponent.new(
      gallery: @gallery,
      tag_search: @tag_search,
      mode: "bulk_add_tag",
      turbo_frame: "bulk-tag-search-results",
      title: "Add tag to selected images"
    )) do |c| %>
      <% c.with_footer do %>
        <%= form_with(
          scope: :bulk_tag,
          url: gallery_bulk_tag_path(
            @gallery,
            **request.query_parameters
          ),
          method: :post,
          data: {action: "submit->dialog#close"}
        ) do |f| %>
          <div data-gallery-bulk-tag-target="selectedIdsContainer"></div>
          <%= f.hidden_field(
            :tag_id,
            data: {gallery_bulk_tag_target: "tagIdInput"}
          ) %>

          <div class="mt-4">
            <p class="text-sm text-gray-600">
              Selected tag:
              <span
                data-gallery-bulk-tag-target="selectedTagName"
                class="font-medium"
              >None selected</span>
            </p>
          </div>

          <div class="mt-6 flex gap-3 justify-end">
            <button
              type="button"
              class="button"
              data-action="dialog#close"
            >
              Cancel
            </button>
            <%= f.submit(
              "Add tag",
              disabled: true,
              class: "button",
              data: {gallery_bulk_tag_target: "confirmButton"}
            ) %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
